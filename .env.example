# OpenAI key — powers the AI Redesign image generation in the Room Visualizer (/api/visualize)
OPENAI_API_KEY=

# Anthropic key — powers "Suggest tiles for this room" in the Room Visualizer (/api/suggest)
# and the floating showroom assistant chatbot (/api/chat). Without it the chat widget
# still opens, but says it isn't configured and points visitors at the showroom phone.
ANTHROPIC_API_KEY=

# PostHog — client-side + server-side capture (public project key, safe to expose).
# Consumed by instrumentation-client.ts (browser, via the /ingest reverse proxy in
# next.config.ts) and src/lib/posthog-server.ts (posthog-node).
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# PostHog — admin Analytics read-back (server-side, SECRET). Needed for /admin/analytics
# to show data. Create a Personal API key (Query Read + Insight Read) and grab the Project ID.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_API_HOST=https://us.posthog.com

# ─────────────────────────────────────────────────────────────────────────────
# Durable data store — REQUIRED IN PRODUCTION.
# The whole database (settings, orders, users, content) lives in Upstash Redis on
# Vercel. WITHOUT these, admin edits (maintenance toggle, settings, orders) silently
# vanish because Vercel's filesystem is ephemeral — this is the #1 "it doesn't save"
# bug. Add the Upstash Redis integration in Vercel → Storage; it injects these.
# Scope them to ALL environments INCLUDING Edge Middleware (the maintenance proxy).
# Local dev needs NOTHING here — it falls back to ./data/db.json automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN are accepted as aliases.)

# Resend — transactional email (order confirmations, status updates, ticket replies,
# team invites). Without RESEND_API_KEY these are stored but not emailed (graceful).
# In Resend test mode the default FROM only delivers to the account owner's verified
# address; verify a domain in Resend to email any customer.
RESEND_API_KEY=
RESEND_FROM=Aster Tiles <onboarding@resend.dev>
# Public base URL, used to build "Track your order" links in emails.
NEXT_PUBLIC_APP_URL=https://aster-tiles.vercel.app
